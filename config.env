# imgui-relocator configuration
# Edit these values to customize the relocation.

# Upstream repo and version to build from
UPSTREAM_REPO="https://github.com/SpaiR/imgui-java.git"
UPSTREAM_TAG="v1.90.0"

# Target Java package (dot notation, >= 3 segments)
# e.g. "com.delta.imgui", "net.mymod.imgui"
TARGET_PKG="com.delta.imgui"

# Maven group ID for published artifacts
MAVEN_GROUP="com.delta"

# Prefix for artifact IDs (e.g. delta-imgui-java-binding)
ARTIFACT_PREFIX="delta-imgui-java"

# Native library base name (without lib prefix or .so/.dll/.dylib suffix)
# e.g. "delta-imgui-java64" → libdelta-imgui-java64.so
LIB_NAME="delta-imgui-java64"
